# ══════════════════════════════════════════════════════════════
# Studio API — Environment Variables
# ══════════════════════════════════════════════════════════════
# Auto-generated from app/lib/config.py — do not edit by hand.
# Re-generate: make env-schema
#
# Copy this file to .env and customise.
# Precedence: .env → .env.local → .env.{{env}} → .env.{{env}}.local

# ── Application ──────────────────────────────────────────────
# Type: str
APP_NAME=Voice Agent OS

# Type: Environment
ENVIRONMENT=development

# Type: bool
DEBUG=false

# Type: str
API_PREFIX=/api

# Type: str
LOG_LEVEL=info

# Type: str
OAUTH_CALLBACK_BASE_URL=http://localhost:3000

# Type: list[str]
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000", "http://studio-web:3000"]

# ── PostgreSQL connection settings. ─────
#
# Env vars: DATABASE_URL, DATABASE_ECHO
# Type: str
DATABASE__URL=postgresql://voice-agent-os:ferosdev@localhost:5432/voice_agent

# Type: bool
DATABASE__ECHO=false

# Type: int
DATABASE__POOL_SIZE=5

# Type: int
DATABASE__MAX_OVERFLOW=10

# ── Redis connection settings. ─────
#
# Env vars: REDIS__URL
# Type: str
# REDIS__URL=

# ── Authentication settings. ─────
#
# Env vars: AUTH_SECRET_KEY, AUTH_API_KEY, AUTH_ACCESS_TOKEN_EXPIRE_MINUTES
# Type: str
# AUTH__SECRET_KEY=dev-secret-change-in-production

# Type: str
AUTH__CREDENTIAL_SALT=voice-agent-os-credential-vault-v1

# Type: str
# AUTH__API_KEY=

# Type: int
# AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Type: str
AUTH__ALGORITHM=HS256

# ── Gemini API settings (used for builder web search). ─────
#
# Env vars: GEMINI__API_KEY
# Type: str
# GEMINI__API_KEY=

