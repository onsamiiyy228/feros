# ══════════════════════════════════════════════════════════════
# Voice Agent OS ML — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy to .env and customize.

# ── Speaches (STT) ───────────────────────────────────────────
# Whisper model to load. Options: tiny, base, small, medium,
# large-v2, large-v3, distil-large-v3
WHISPER_MODEL=large-v3

# ── GPU Assignment ───────────────────────────────────────────
# Both STT and TTS share this GPU. Combined VRAM ~8GB.
# Default: GPU 1 (leave GPU 0 free for other workloads)
GPU=1
