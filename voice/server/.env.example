# ══════════════════════════════════════════════════════════════
# voice-server — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and customise.
#
# NOTE: Provider settings (STT, LLM, TTS, Telephony) are NOT
# configured here. They live in the `provider_configs` table and
# are managed through the Settings page in the UI.

# ── Server ───────────────────────────────────────────────────
# SERVER__LISTEN_HOST=0.0.0.0
# SERVER__LISTEN_PORT=8300

# ── Database ─────────────────────────────────────────────────
# Same Postgres instance and env name as studio/api.
DATABASE__URL=postgresql://voice-agent-os:ferosdev@localhost:5432/voice_agent

# ── Session Secret ───────────────────────────────────────────
# The only auth value voice-server needs from studio/api.
#
# studio/api has three auth settings:
#   AUTH__SECRET_KEY       ← use the same value here
#   AUTH__CREDENTIAL_SALT  ← vault encryption only, not needed here
#   AUTH__ALGORITHM        ← JWT algorithm (HS256), not needed here
#                            (voice-server uses HMAC-SHA256 directly)
#
# Must be identical to AUTH__SECRET_KEY so that session tokens are
# mutually verifiable between studio/api and voice-server.
# Leave empty to skip token validation (dev mode only).
AUTH__SECRET_KEY=dev-secret-change-in-production

# ── WebRTC / STUN / TURN ─────────────────────────────────────
# Read directly by voice/engine's IceConfig — no studio/api needed.
#
# Option A: Cloudflare managed TURN (recommended for production)
# CF__TURN_KEY_ID=your-cloudflare-turn-key-id
# CF__TURN_KEY_API_TOKEN=your-cloudflare-turn-api-token
# CF__TURN_TTL=86400
#
# Option B: Self-hosted / static TURN (coturn, Twilio TURN, Xirsys, etc.)
# TURN__URLS=turn:your-turn-server:3478,turns:your-turn-server:5349
# TURN__USERNAME=your-turn-username
# TURN__CREDENTIAL=your-turn-credential
#
# STUN only — sufficient for most LAN/dev setups (no TURN needed)
# No config required: falls back to stun.cloudflare.com:3478 by default.

# ── Recordings ────────────────────────────────────────────────
# Directory URI where session recordings (audio + transcript JSON) are stored.
# Set this to a Docker volume mount path in production so recordings persist
# across container restarts. Currently only `file://` scheme is supported.
#   e.g. file:///recordings  (Docker volume mount)
#   e.g. file://./recordings (local dev — relative to the working directory)
#
# Recording is opt-out — all sessions are recorded unless the agent graph
# explicitly sets recording.enabled = false.
# RECORDING__OUTPUT_URI=file://./recordings

# ── Agent Kit (Background Tasks) ──────────────────────────────
# Flags for enabling safety, summarization, and filler logic.
AGENT__TOOL_SUMMARIZER=true
AGENT__CONTEXT_SUMMARIZER=true
AGENT__TOOL_FILLER=false
